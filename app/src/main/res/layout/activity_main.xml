<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="লাফি অ্যাসিস্ট্যান্ট"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FF6B00"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/btn_microphone"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:text="🎤"
        android:textSize="60sp"
        android:backgroundTint="#FF6B00"
        app:cornerRadius="75dp"
        android:layout_marginBottom="40dp" />

    <TextView
        android:id="@+id/tv_output"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="মাইক্রোফোনে ক্লিক করুন এবং বলুন..."
        android:textAlignment="center"
        android:textSize="18sp"
        android:textColor="#333333"
        android:padding="20dp"
        android:background="@drawable/output_background"
        android:minHeight="100dp" />

</LinearLayout>
